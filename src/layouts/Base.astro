---
import '../styles/global.css';
import { contact } from '../data/content.js';
import { t, pad, talen, taalNamen, type Taal } from '../i18n/index.ts';

const {
  taal = 'nl' as Taal,
  title,
  description,
  ogImage,           // pagina-eigen deelafbeelding (absolute of /assets-pad)
  ogType = 'website',
  jsonld,            // extra structured data voor deze pagina (Article, Event…)
  noindex = false,
} = Astro.props;

const paginaTitel = title ?? t(taal, 'home.titel');
const paginaOmschrijving = description ?? t(taal, 'home.omschrijving');

// Het huidige pad zonder taalvoorvoegsel, zodat de taalwisselaar naar
// dezelfde pagina in een andere taal kan verwijzen.
const huidigPad = Astro.url.pathname.replace(/^\/(en|id)(?=\/|$)/, '') || '/';

// Basis-URL voor canonical, sitemap en Open Graph
const siteURL = Astro.site ?? new URL('https://gema-rasa-site.pages.dev');
const canonical = new URL(Astro.url.pathname, siteURL).toString();
const deelAfbeelding = new URL(ogImage ?? '/assets/perf-wayang.jpg', siteURL).toString();
const ogLocale = { nl: 'nl_NL', en: 'en_GB', id: 'id_ID' }[taal];

// Organisatie-gegevens: helpt Google én AI-zoekmachines begrijpen wie je bent.
const organisatie = {
  '@context': 'https://schema.org',
  '@type': ['NGO', 'PerformingGroup'],
  name: 'Stichting Gema Rasa',
  alternateName: 'Gema Rasa',
  url: siteURL.origin,
  logo: new URL('/assets/logo.png', siteURL).toString(),
  image: deelAfbeelding,
  description: t('nl', 'home.omschrijving'),
  email: contact.email,
  telephone: contact.telefoon,
  foundingDate: '2024-01-17',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Aan de Botersloot 2',
    addressLocality: 'Ammerstol',
    addressCountry: 'NL',
  },
  sameAs: [
    'https://www.youtube.com/@StichtingGemaRasa',
    'https://www.instagram.com/stichtinggemarasa',
    'https://www.facebook.com/stichtinggemarasa',
    'https://www.linkedin.com/company/102107834/',
  ],
};

// Menustructuur: drie groepen plus twee losse items. Zo blijft de balk kort
// en vindt een bezoeker sneller wat hij zoekt.
const menu = [
  { sleutel: 'nav.over', items: [
      { sleutel: 'nav.stichting', url: '/de-stichting' },
      { sleutel: 'nav.leden', url: '/leden' },
      { sleutel: 'nav.vrienden', url: '/de-vrienden-van' },
  ] },
  { sleutel: 'nav.groepen', items: [
      { sleutel: 'nav.gamelan', url: '/de-gamelan-groep' },
      { sleutel: 'nav.dans', url: '/de-dansgroep' },
  ] },
  { sleutel: 'nav.media', items: [
      { sleutel: 'nav.nieuws', url: '/nieuws' },
      { sleutel: 'nav.videos', url: '/videos' },
      { sleutel: 'nav.albums', url: '/albums' },
      { sleutel: 'nav.magazine', url: '/suwara-jawa' },
  ] },
  { sleutel: 'nav.boeken', url: '/menukaart' },
  { sleutel: 'nav.contact', url: '/contact' },
];
const actief = (u) => huidigPad === u || huidigPad.startsWith(u + '/');
---
<!DOCTYPE html>
<html lang={taal}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{paginaTitel}</title>
  <meta name="description" content={paginaOmschrijving} />
  {noindex && <meta name="robots" content="noindex,follow" />}
  <link rel="canonical" href={canonical} />

  {/* Talen: verwijzingen naar dezelfde pagina in andere talen */}
  {talen.map((andere) => (
    <link rel="alternate" hreflang={andere} href={new URL(pad(andere, huidigPad), siteURL).toString()} />
  ))}
  <link rel="alternate" hreflang="x-default" href={new URL(pad('nl', huidigPad), siteURL).toString()} />

  {/* Open Graph — mooie voorvertoning bij delen op social/WhatsApp */}
  <meta property="og:type" content={ogType} />
  <meta property="og:title" content={paginaTitel} />
  <meta property="og:description" content={paginaOmschrijving} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={deelAfbeelding} />
  <meta property="og:site_name" content="Stichting Gema Rasa" />
  <meta property="og:locale" content={ogLocale} />

  {/* Twitter/X */}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={paginaTitel} />
  <meta name="twitter:description" content={paginaOmschrijving} />
  <meta name="twitter:image" content={deelAfbeelding} />

  {/* Structured data: wie we zijn (voor Google + AI-zoekmachines) */}
  <script type="application/ld+json" is:inline set:html={JSON.stringify(organisatie)} />
  {jsonld && <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonld)} />}
  <link rel="icon" type="image/png" href="/assets/icon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600;12..96,700;12..96,800&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <script is:inline>
    // Zet animaties aan vóór de eerste weergave (voorkomt flikkering).
    // Respecteert de systeeminstelling 'verminderde beweging'.
    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      document.documentElement.classList.add('anim');
    }
  </script>
</head>
<body
  data-msg-bezig={t(taal, 'form.bezig')}
  data-msg-bedankt={t(taal, 'form.bedankt')}
  data-msg-fout={t(taal, 'form.fout')}
  data-msg-offline={t(taal, 'form.offline')}
>
  <header>
    <div class="wrap">
      <nav>
        <a class="brand" href={pad(taal, '/')}>
          <img class="logo-img" src="/assets/logo.png" alt="Stichting Gema Rasa" />
        </a>
        <div class="navlinks">
          {menu.map((m) => (m.items ? (
            <div class="nav-groep">
              <button class="nav-knop" aria-expanded="false" aria-haspopup="true">
                {t(taal, m.sleutel)}<span class="pijl" aria-hidden="true"></span>
              </button>
              <div class="submenu">
                {m.items.map((i) => (
                  <a href={pad(taal, i.url)} class={actief(i.url) ? 'hier' : undefined}>{t(taal, i.sleutel)}</a>
                ))}
              </div>
            </div>
          ) : (
            <a href={pad(taal, m.url)} class={actief(m.url) ? 'hier' : undefined}>{t(taal, m.sleutel)}</a>
          )))}
        </div>
        <div class="nav-right">
          <div class="lang" role="group" aria-label="Taal kiezen">
            {talen.map((andere, i) => (
              <>
                {i > 0 && <span class="scheider">·</span>}
                <a
                  href={pad(andere, huidigPad)}
                  hreflang={andere}
                  title={taalNamen[andere]}
                  aria-current={andere === taal ? 'true' : undefined}
                  class={andere === taal ? 'actief' : undefined}
                >{andere.toUpperCase()}</a>
              </>
            ))}
          </div>
          <a class="btn gold steun-knop" href={pad(taal, '/steun')}>{t(taal, 'nav.steun')}</a>
          <button class="hamburger" id="menuKnop" aria-expanded="false" aria-controls="mobielMenu"
                  aria-label={t(taal, 'nav.menuOpen')}
                  data-open={t(taal, 'nav.menuOpen')} data-sluit={t(taal, 'nav.menuSluit')}>
            <span aria-hidden="true"></span><span aria-hidden="true"></span><span aria-hidden="true"></span>
          </button>
        </div>
      </nav>
    </div>
  </header>

  <!-- Mobiel menu: alle links gegroepeerd, in één keer zichtbaar -->
  <div class="mobiel-menu" id="mobielMenu" hidden>
    <nav class="mobiel-inner">
      {menu.map((m) => (
        <div class="mobiel-groep">
          {m.items ? (
            <>
              <h4>{t(taal, m.sleutel)}</h4>
              {m.items.map((i) => (
                <a href={pad(taal, i.url)} class={actief(i.url) ? 'hier' : undefined}>{t(taal, i.sleutel)}</a>
              ))}
            </>
          ) : (
            <a class="los" href={pad(taal, m.url)}>{t(taal, m.sleutel)}</a>
          )}
        </div>
      ))}
      <div class="mobiel-groep">
        <h4>{t(taal, 'nav.taal')}</h4>
        <div class="mobiel-talen">
          {talen.map((andere) => (
            <a href={pad(andere, huidigPad)} hreflang={andere}
               class={andere === taal ? 'actief' : undefined}>{taalNamen[andere]}</a>
          ))}
        </div>
      </div>
      <a class="btn gold mobiel-steun" href={pad(taal, '/steun')}>{t(taal, 'nav.steun')}</a>
    </nav>
  </div>

  <slot />

  <footer>
    <div class="wrap">
      <div class="fgrid">
        <div>
          <span class="name" style="color:#fff;font-weight:700;font-size:18px">Stichting Gema Rasa</span>
          <p style="margin-top:14px">{t(taal, 'footer.over')}</p>
          <form class="newsletter" data-formulier="nieuwsbrief" data-bedankt={t(taal, 'form.bedanktNieuwsbrief')}>
            <label for="nl-email">{t(taal, 'footer.nieuwsbrief')}</label>
            <div class="nl-row">
              <input id="nl-email" name="email" type="email" required placeholder={t(taal, 'footer.emailPlaceholder')} aria-label="E-mail" />
              <button class="btn gold" type="submit">{t(taal, 'footer.inschrijven')}</button>
            </div>
            <label class="akkoord">
              <input type="checkbox" name="toestemming" required />
              <span>{t(taal, 'footer.akkoord')}</span>
            </label>
            {/* Verborgen veld tegen spambots */}
            <input type="text" name="website" tabindex="-1" autocomplete="off" class="honeypot" aria-hidden="true" />
            <p class="form-status" data-status role="status" aria-live="polite"></p>
          </form>
        </div>
        <div>
          <h4>{t(taal, 'footer.links')}</h4>
          <a href={pad(taal, '/')}>{t(taal, 'nav.home')}</a>
          <a href={pad(taal, '/de-stichting')}>{t(taal, 'nav.stichting')}</a>
          <a href={pad(taal, '/leden')}>{t(taal, 'nav.leden')}</a>
          <a href={pad(taal, '/de-gamelan-groep')}>{t(taal, 'nav.gamelan')}</a>
          <a href={pad(taal, '/de-dansgroep')}>{t(taal, 'nav.dans')}</a>
          <a href={pad(taal, '/videos')}>{t(taal, 'nav.videos')}</a>
          <a href={pad(taal, '/suwara-jawa')}>{t(taal, 'nav.magazine')}</a>
          <a href={pad(taal, '/de-vrienden-van')}>{t(taal, 'nav.vrienden')}</a>
        </div>
        <div>
          <h4>{t(taal, 'footer.contactgegevens')}</h4>
          <a href={`mailto:${contact.email}`}>{contact.email}</a>
          <a href={`tel:${contact.telefoon.replace(/[^+0-9]/g, '')}`}>{contact.telefoon}</a>
          <p>{contact.adres}</p>
          <p style="margin-top:10px;font-size:12.5px">KVK: {contact.kvk}<br>BTW: {contact.btw}</p>
        </div>
      </div>
      <div class="fbar">
        <span>{t(taal, 'footer.rechten')}</span>
        <span>{t(taal, 'footer.slogan')}</span>
      </div>
    </div>
  </footer>

  <script>
    // Elementen die bij het scrollen in beeld komen, gefaseerd tonen
    const SEL = '.section-head,.card,.news,.member,.agenda .row,.feature,.merch,' +
                '.duo .word,.values .v,.info-card,.vcard,.prod .inner>*,.cta-inner>*';

    if (document.documentElement.classList.contains('anim')) {
      let resterend = Array.from(document.querySelectorAll<HTMLElement>(SEL));

      // Vertraging per element binnen dezelfde groep (trapsgewijs effect)
      const teller = new Map<Element | null, number>();
      resterend.forEach((el) => {
        const ouder = el.parentElement;
        const i = teller.get(ouder) ?? 0;
        teller.set(ouder, i + 1);
        el.style.setProperty('--d', `${Math.min(i, 8) * 70}ms`);
      });

      // Toon alles dat in beeld is óf er al voorbij gescrold is.
      // Bewust op scrollpositie i.p.v. een waarnemer: bij snel scrollen of
      // springen naar een anker mag nooit iets onzichtbaar achterblijven.
      const toon = () => {
        const grens = window.innerHeight * 0.92;
        resterend = resterend.filter((el) => {
          if (el.getBoundingClientRect().top < grens) {
            el.classList.add('is-visible');
            return false;
          }
          return true;
        });
        if (!resterend.length) {
          window.removeEventListener('scroll', bijScrollAnim);
          window.removeEventListener('resize', bijScrollAnim);
          clearInterval(hartslag);
        }
      };

      let gepland = false;
      const bijScrollAnim = () => {
        if (gepland) return;
        gepland = true;
        requestAnimationFrame(() => { gepland = false; toon(); });
      };

      window.addEventListener('scroll', bijScrollAnim, { passive: true });
      window.addEventListener('resize', bijScrollAnim, { passive: true });

      // Vangnet: elke seconde kijken wat er in beeld staat. Zo blijft er nooit iets
      // onzichtbaar hangen als scroll-events niet aankomen, én onthullen we niets
      // te vroeg — het effect blijft dus behouden.
      const hartslag = setInterval(toon, 1000);

      toon(); // direct, niet via een animatieframe — werkt ook als rAF vertraagd is

      // --- Parallax op hero-beelden: de achtergrond schuift trager mee ---
      const lagen = Array.from(document.querySelectorAll<HTMLElement>('[data-parallax], .hero'));
      if (lagen.length) {
        let bezig = false;
        const verschuif = () => {
          const h = window.innerHeight;
          lagen.forEach((el) => {
            const r = el.getBoundingClientRect();
            if (r.bottom < -200 || r.top > h + 200) return; // buiten beeld: overslaan
            const voortgang = (r.top + r.height / 2 - h / 2) / h; // -1 … 1
            el.style.setProperty('--par', `${(voortgang * 190).toFixed(1)}px`);
          });
        };
        const bijScrollPar = () => {
          if (bezig) return;
          bezig = true;
          requestAnimationFrame(() => { bezig = false; verschuif(); });
        };
        window.addEventListener('scroll', bijScrollPar, { passive: true });
        window.addEventListener('resize', bijScrollPar, { passive: true });
        verschuif();
      }
    }

    // --- Mobiel menu openen/sluiten ---
    const menuKnop = document.getElementById('menuKnop');
    const mobielMenu = document.getElementById('mobielMenu');

    const zetMenu = (open: boolean) => {
      if (!menuKnop || !mobielMenu) return;
      menuKnop.setAttribute('aria-expanded', String(open));
      menuKnop.setAttribute('aria-label', (open ? menuKnop.dataset.sluit : menuKnop.dataset.open) || '');
      mobielMenu.hidden = !open;
      document.body.classList.toggle('menu-open', open);
    };

    menuKnop?.addEventListener('click', () => {
      zetMenu(menuKnop.getAttribute('aria-expanded') !== 'true');
    });

    // Sluiten bij klikken op een link, bij Escape, en bij verbreden naar desktop
    mobielMenu?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => zetMenu(false)));
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') zetMenu(false); });
    window.addEventListener('resize', () => { if (window.innerWidth > 1080) zetMenu(false); });

    // Schaduw onder de header zodra er gescrold wordt
    const kop = document.querySelector('header');
    const bijScroll = () => kop?.classList.toggle('scrolled', window.scrollY > 8);
    bijScroll();
    window.addEventListener('scroll', bijScroll, { passive: true });

    // --- Formulieren versturen (contact, nieuwsbrief, vrijwilliger) ---
    // Meldingen komen uit de layout, zodat ze in de juiste taal staan
    const m = document.body.dataset;

    document.querySelectorAll<HTMLFormElement>('form[data-formulier]').forEach((form) => {
      const status = form.querySelector<HTMLElement>('[data-status]');
      const knop = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      const knopTekst = knop?.textContent ?? '';

      const meld = (tekst: string, gelukt: boolean) => {
        if (!status) return;
        status.textContent = tekst;
        status.dataset.staat = gelukt ? 'ok' : 'fout';
      };

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const velden = Object.fromEntries(new FormData(form) as any);
        velden.soort = form.dataset.formulier;

        if (knop) { knop.disabled = true; knop.textContent = m.msgBezig || 'Bezig…'; }
        meld('', true);

        try {
          const res = await fetch('/api/formulier', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify(velden),
          });
          const uitslag = await res.json().catch(() => ({ ok: false }));

          if (res.ok && uitslag.ok) {
            form.reset();
            meld(form.dataset.bedankt || m.msgBedankt || '', true);
          } else {
            meld(uitslag.fout || m.msgFout || '', false);
          }
        } catch {
          meld(m.msgOffline || '', false);
        } finally {
          if (knop) { knop.disabled = false; knop.textContent = knopTekst; }
        }
      });
    });
  </script>
</body>
</html>
