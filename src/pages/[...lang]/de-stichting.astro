---
import { taalPaden, t, pad } from '../../i18n/index.ts';
export const getStaticPaths = taalPaden;
const { taal } = Astro.props;
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
---
<Base taal={taal} title="De Stichting — Stichting Gema Rasa">
  <PageHero
    sleutel="de-stichting"
    eyebrow={t(taal, "st.eyebrow")}
    titel={t(taal, "st.titel")}
    tekst={t(taal, "st.intro")}
    foto="/assets/perf-expo.jpg"
  />

  <section class="block">
    <div class="wrap">
      <div class="prose">
        <p class="lead">{t(taal, "st.lead")}</p>
        <p>{t(taal, "st.p1")}</p>

        <h2>{t(taal, "st.naamKop")}</h2>
        <h3>{t(taal, "st.gemaKop")}</h3>
        <p>{t(taal, "st.gemaTekst")}</p>
        <h3>{t(taal, "st.rasaKop")}</h3>
        <p>{t(taal, "st.rasaTekst")}</p>

        <h2>{t(taal, "st.visieKop")}</h2>
        <p>{t(taal, "st.visieTekst")}</p>

        <h2>{t(taal, "st.missieKop")}</h2>
        <p>{t(taal, "st.missieTekst")}</p>
      </div>
    </div>
  </section>

  <!-- CTA: menukaart -->
  <section class="cta soft" style="margin-bottom:20px">
    <div class="cta-inner">
      <span class="eyebrow" style="justify-content:center;color:var(--orange)">{t(taal, "st.ctaKicker")}</span>
      <h2>{t(taal, "st.ctaTitel")}</h2>
      <p>{t(taal, "st.ctaTekst")}</p>
      <a class="btn gold" href={pad(taal, "/menukaart")}>{t(taal, "st.ctaKnop")}</a>
    </div>
  </section>

  <section class="cta">
    <div class="cta-inner">
      <h2>{t(taal, "st.steunTitel")}</h2>
      <p>{t(taal, "st.steunTekst")}</p>
      <a class="btn" href={pad(taal, "/steun")}>{t(taal, "st.steunKnop")}</a>
    </div>
  </section>
</Base>
