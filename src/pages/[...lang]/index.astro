---
import { taalPaden, t, pad } from '../../i18n/index.ts';
export const getStaticPaths = taalPaden;
const { taal } = Astro.props;
import Base from '../../layouts/Base.astro';
import { getHomepage, getNieuws, getAgenda, getGalerij } from '../../lib/sanity.ts';

const { hero, productie, merch, seo: paginaSeo } = await getHomepage(taal);
const nieuws = await getNieuws(taal);
const agenda = await getAgenda(taal);
const galerij = await getGalerij();

// Titel met accent-woord in goud (uit CMS)
const [voorAccent, naAccent] = hero.titelAccent && hero.titel.includes(hero.titelAccent)
  ? hero.titel.split(hero.titelAccent)
  : [hero.titel, ''];
---
<Base taal={taal} seo={paginaSeo}>
  <!-- HERO (via CMS) -->
  <section class="hero" id="top" style={`--hero-img:url('${hero.afbeelding}')`}>
    <div class="wrap">
      <div class="hero-inner">
        <span class="eyebrow">{hero.eyebrow}</span>
        <h1>{voorAccent}{naAccent && <em>{hero.titelAccent}</em>}{naAccent}</h1>
        <p class="lead">{hero.tekst}</p>
        <div class="hero-cta">
          <a class="btn gold" href={hero.knopUrl}>{hero.knopLabel}</a>
          <a class="btn ghost" style="color:var(--cream);border-color:rgba(239,200,62,.5)" href="#nieuws">{t(taal, "home.bekijkNieuws")}</a>
        </div>
      </div>
    </div>
  </section>

  <div class="strip">
    <div class="wrap">
      <span>{t(taal, "home.strip1")}</span>
      <span>{t(taal, "home.strip2")}</span>
      <span>{t(taal, "home.strip3")}</span>
      <span>{t(taal, "home.strip4")}</span>
    </div>
  </div>

  <!-- UITGELICHTE PRODUCTIE (via CMS) -->
  {productie.actief && (
    <section class="block prod rond-boven rond-onder" id="productie" data-parallax>
      <div class="wrap">
        <div class="inner">
          <div class="art" style={`background-image:url('${productie.afbeelding}')`}>
            <span class="date-badge">{productie.datumLabel}</span>
          </div>
          <div>
            <span class="kicker" style="color:var(--primary);font-family:'Poppins';font-weight:600;letter-spacing:.13em;text-transform:uppercase;font-size:12.5px">{productie.kicker}</span>
            <h2>{productie.titel}</h2>
            <p>{productie.intro}</p>
            <p>{productie.beschrijving}</p>
            {productie.citaat && <p class="quote">"{productie.citaat}"</p>}
            <a class="btn gold" href={productie.knopUrl}>{productie.knopLabel}</a>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- MERCHANDISE (via CMS) -->
  {merch.actief && (
    <section class="block" style="padding-top:0">
      <div class="wrap">
        <div class="merch">
          <div class="img" style={`background-image:url('${merch.afbeelding || "/assets/perf4.jpg"}')`}></div>
          <div class="body">
            <span class="kicker">{merch.kicker || t(taal, "home.merchKicker")}</span>
            <h2>{merch.titel || t(taal, "home.merchTitel")}</h2>
            <p>{merch.tekst1 || t(taal, "home.merchTekst1")}</p>
            {(merch.tekst2 || t(taal, "home.merchTekst2")) && (
              <p>{merch.tekst2 || t(taal, "home.merchTekst2")}</p>
            )}
            <a class="btn" href={pad(taal, merch.knopUrl || "/shop")} style="margin-top:8px">
              {merch.knopLabel || t(taal, "home.shop")}
            </a>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- OVER DE STICHTING: GEMA & RASA -->
  <section class="block batik" id="over" style="padding-top:0">
    <div class="wrap">
      <div class="ornament" style="margin-bottom:52px"><span></span></div>
      <div class="section-head">
        <span class="kicker">{t(taal, "home.overKicker")}</span>
        <h2>{t(taal, "home.overTitel")}</h2>
        <p>{t(taal, "home.overTekst")}</p>
      </div>
      <div class="duo">
        <div class="word">
          <h3>Gema</h3>
          <p>{t(taal, "home.gemaTekst")}</p>
        </div>
        <div class="word">
          <h3>Rasa</h3>
          <p>{t(taal, "home.rasaTekst")}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- BEWEGENDE FOTOSTROOK (via CMS) -->
  {galerij.length > 0 && (
    <section class="strook rond-boven rond-onder" id="fotos">
      <div class="kop">
        <span class="kicker">{t(taal, "home.fotoKicker")}</span>
        <h2>{t(taal, "home.fotoTitel")}</h2>
        <div class="ornament op-donker" style="margin-top:18px"><span></span></div>
      </div>
      <div class="marquee">
        <div class="marquee-track">
          {[...galerij, ...galerij].map((f, i) => (
            <figure>
              <img src={f.url} alt={f.bijschrift || 'Stichting Gema Rasa'} loading="lazy" aria-hidden={i >= galerij.length ? 'true' : undefined} />
              {f.bijschrift && <figcaption>{f.bijschrift}</figcaption>}
            </figure>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- NIEUWS -->
  <section class="block" id="nieuws" style="padding-top:0">
    <div class="wrap">
      <div class="section-head">
        <span class="kicker">{t(taal, "home.nieuwsKicker")}</span>
        <h2>{t(taal, "home.nieuwsTitel")}</h2>
        <p>{t(taal, "home.nieuwsTekst")}</p>
        <p style="margin-top:14px"><a class="btn ghost" href={pad(taal, "/nieuws")}>{t(taal, "home.alleBerichten")}</a></p>
      </div>
      <div class="news-grid">
        {nieuws.map((n) => (
          <a class="news" href={pad(taal, `/nieuws/${n.slug}`)}>
            <div class="thumb" style={`background-image:url('${n.afbeelding}')`}></div>
            <div class="np">
              <span class="cat">{n.categorie}</span>
              <h3>{n.titel}</h3>
              <p>{n.intro.length > 160 ? n.intro.slice(0, 160) + '…' : n.intro}</p>
              <span class="more">{t(taal, "algemeen.leesMeer")} →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA: BOEK GEMA RASA → menukaart -->
  <section class="cta">
    <div class="cta-inner">
      <h2>{t(taal, "home.ctaTitel")}</h2>
      <p>{t(taal, "home.ctaTekst")}</p>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap">
        <a class="btn" href={pad(taal, "/menukaart")}>{t(taal, "home.ctaKnop")}</a>
        <a class="btn ghost" href={pad(taal, "/contact")}>{t(taal, "home.ctaContact")}</a>
      </div>
    </div>
  </section>

  <!-- AGENDA -->
  <section class="block" id="agenda">
    <div class="wrap">
      <div class="section-head">
        <span class="kicker">{t(taal, "home.agendaKicker")}</span>
        <h2>{t(taal, "home.agendaTitel")}</h2>
        <p>{t(taal, "home.agendaTekst")}</p>
      </div>
      <div class="agenda">
        {agenda.map((e) => (
          <div class="row">
            <span class="d">{e.datumLabel}</span>
            <span class="t">{e.titel}</span>
            <span class="loc">{e.locatie}</span>
          </div>
        ))}
      </div>
    </div>
  </section>
</Base>
