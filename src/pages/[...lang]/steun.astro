---
import { taalPaden, t, pad } from '../../i18n/index.ts';
export const getStaticPaths = taalPaden;
const { taal } = Astro.props;
const paginaSeo = await getPaginaSeo('steun');
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
import { getDoneren , getPaginaSeo} from '../../lib/sanity.ts';
const doneren = await getDoneren();

const manieren = [
  { titel: t(taal, "sn.m1t"), tekst: t(taal, "sn.m1b") },
  { titel: t(taal, "sn.m2t"), tekst: t(taal, "sn.m2b") },
  { titel: t(taal, "sn.m3t"), tekst: t(taal, "sn.m3b") },
  { titel: t(taal, "sn.m4t"), tekst: t(taal, "sn.m4b") },
];
---
<Base taal={taal} seo={paginaSeo} description={t(taal, "sn.intro")} title={`${t(taal, "sn.titel")} — Stichting Gema Rasa`}>
  <PageHero
    sleutel="steun"
    eyebrow={t(taal, "sn.eyebrow")}
    titel={t(taal, "sn.titel")}
    tekst={t(taal, "sn.intro")}
    foto="/assets/perf-wayang.jpg"
  />

  <!-- DONEREN (via CMS) -->
  {(!doneren || doneren.actief) && (
    <section class="block doneer-sectie">
      <div class="wrap">
        <div class="section-head">
          <span class="kicker">{t(taal, "dn.kicker")}</span>
          <h2>{doneren?.titel || t(taal, "dn.titel")}</h2>
          <p>{doneren?.tekst || t(taal, "dn.tekst")}</p>
        </div>

        {doneren?.bestemming && <p class="doneer-bestemming">{doneren.bestemming}</p>}

        {(doneren?.bedragen?.length || doneren?.vrijBedragUrl || doneren?.maandelijksUrl || doneren?.iban) ? (
          <div class="doneer-grid">
            {/* Eenmalig */}
            {(doneren.bedragen.length > 0 || doneren.vrijBedragUrl) && (
              <div class="doneer-kaart">
                <h3>{t(taal, "dn.eenmalig")}</h3>
                <div class="bedragen">
                  {doneren.bedragen.map((b) => (
                    <a class="bedrag" href={b.url} target="_blank" rel="noopener">
                      <span class="bedrag-euro">€{b.bedrag}</span>
                      {b.toelichting && <span class="bedrag-uitleg">{b.toelichting}</span>}
                    </a>
                  ))}
                  {doneren.vrijBedragUrl && (
                    <a class="bedrag vrij" href={doneren.vrijBedragUrl} target="_blank" rel="noopener">
                      <span class="bedrag-euro">{t(taal, "dn.eigenBedrag")}</span>
                    </a>
                  )}
                </div>
              </div>
            )}

            {/* Maandelijks */}
            {doneren.maandelijksUrl && (
              <div class="doneer-kaart uitgelicht">
                <h3>{t(taal, "dn.maandelijks")}</h3>
                <p>{doneren.maandelijksTekst || t(taal, "dn.maandelijksTekst")}</p>
                <a class="btn gold" href={doneren.maandelijksUrl} target="_blank" rel="noopener">
                  {t(taal, "dn.maandelijksKnop")}
                </a>
              </div>
            )}

            {/* Overschrijving */}
            {doneren.iban && (
              <div class="doneer-kaart">
                <h3>{t(taal, "dn.bank")}</h3>
                <p>{doneren.bankTekst || t(taal, "dn.bankTekst")}</p>
                <div class="iban-rij">
                  <code id="ibanWaarde">{doneren.iban}</code>
                  <button class="btn ghost iban-knop" id="ibanKnop"
                          data-kopieer={t(taal, "dn.kopieer")} data-gekopieerd={t(taal, "dn.gekopieerd")}>
                    {t(taal, "dn.kopieer")}
                  </button>
                </div>
                <span class="iban-tnv">{t(taal, "dn.tnv")} {doneren.tenaamstelling}</span>
              </div>
            )}
          </div>
        ) : (
          <p class="ens-leeg">{t(taal, "dn.nogNiet")}</p>
        )}
      </div>
    </section>
  )}

  <section class="block" style="padding-top:0">
    <div class="wrap">
      <div class="section-head"><span class="kicker">{t(taal, "dn.anders")}</span></div>
      <div class="team-grid">
        {manieren.map((m) => (
          <div class="member" style="padding:26px">
            <div class="naam" style="font-size:19px">{m.titel}</div>
            <div class="rol" style="font-size:14px;color:#4a4a4a;margin-top:8px;line-height:1.5">{m.tekst}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- AANMELDEN ALS VRIJWILLIGER / LID -->
  <section class="block" id="aanmelden" style="padding-top:0">
    <div class="wrap">
      <div class="split">
        <div>
          <div class="section-head" style="margin-bottom:22px">
            <span class="kicker">{t(taal, "sn.aanmeldKicker")}</span>
            <h2>{t(taal, "sn.aanmeldTitel")}</h2>
            <p>{t(taal, "sn.aanmeldTekst")}</p>
          </div>
          <form class="cform" data-formulier="vrijwilliger" data-bedankt={t(taal, "sn.bedankt")}>
            <div>
              <label for="v-naam">{t(taal, "ct.naam")}</label>
              <input id="v-naam" name="naam" type="text" required />
            </div>
            <div>
              <label for="v-email">{t(taal, "ct.email")}</label>
              <input id="v-email" name="email" type="email" required />
            </div>
            <div>
              <label for="v-toelichting">{t(taal, "sn.waarmee")}</label>
              <textarea id="v-toelichting" name="toelichting" placeholder={t(taal, "sn.waarmeeHint")}></textarea>
            </div>
            <label class="akkoord donker">
              <input type="checkbox" name="toestemming" required />
              <span>{t(taal, "sn.akkoord")}</span>
            </label>
            <input type="text" name="website" tabindex="-1" autocomplete="off" class="honeypot" aria-hidden="true" />
            <button class="btn gold" type="submit" style="justify-self:start">{t(taal, "sn.aanmelden")}</button>
            <p class="form-status" data-status role="status" aria-live="polite"></p>
          </form>
        </div>
        <div>
          <div class="info-card">
            <h3>{t(taal, "sn.oefenKop")}</h3>
            <p>{t(taal, "sn.oefenTekst")}</p>
            <p style="margin-top:12px">{t(taal, "sn.oefenTekst2")}</p>
          </div>
          <div class="info-card" style="margin-top:18px">
            <h3>{t(taal, "sn.pratenKop")}</h3>
            <p>{t(taal, "sn.pratenTekst")}</p>
            <a href={pad(taal, "/contact")} class="btn" style="margin-top:10px">{t(taal, "sn.pratenKnop")}</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>

<script>
  const knop = document.getElementById('ibanKnop') as HTMLButtonElement | null;
  knop?.addEventListener('click', async () => {
    const waarde = document.getElementById('ibanWaarde')?.textContent?.trim() || '';
    try {
      await navigator.clipboard.writeText(waarde.replace(/\s+/g, ''));
      knop.textContent = knop.dataset.gekopieerd || 'OK';
      setTimeout(() => { knop.textContent = knop.dataset.kopieer || ''; }, 2200);
    } catch { /* kopiëren geweigerd — gebruiker kan het handmatig selecteren */ }
  });
</script>
