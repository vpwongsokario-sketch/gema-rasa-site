---
import { taalPaden, t, pad } from '../../../i18n/index.ts';
export const getStaticPaths = taalPaden;
const { taal } = Astro.props;
const paginaSeo = await getPaginaSeo('nieuws');
import Base from '../../../layouts/Base.astro';
import PageHero from '../../../components/PageHero.astro';
import { getNieuwsArtikelen , getPaginaSeo} from '../../../lib/sanity.ts';

const artikelen = await getNieuwsArtikelen(taal);
---
<Base taal={taal} seo={paginaSeo} description={t(taal, "nw.intro")} title={`${t(taal, "nw.titel")} — Stichting Gema Rasa`}>
  <PageHero
    sleutel="nieuws"
    eyebrow={t(taal, "nw.eyebrow")}
    titel={t(taal, "nw.titel")}
    tekst={t(taal, "nw.intro")}
    foto="/assets/perf3.jpg"
  />

  <section class="block">
    <div class="wrap">
      <div class="news-grid">
        {artikelen.map((n) => (
          <a class="news" href={pad(taal, `/nieuws/${n.slug}`)}>
            <div class="thumb" style={`background-image:url('${n.afbeelding}')`}></div>
            <div class="np">
              <span class="cat">{n.categorie}</span>
              <h3>{n.titel}</h3>
              <p>{n.intro.length > 160 ? n.intro.slice(0, 160) + '…' : n.intro}</p>
              <span class="more">{t(taal, "algemeen.leesMeer")} →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>
