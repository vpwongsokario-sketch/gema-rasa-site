---
import Base from '../../../layouts/Base.astro';
import { getNieuwsArtikelen } from '../../../lib/sanity.ts';
import { talen, t, pad } from '../../../i18n/index.ts';
import { toHTML } from '@portabletext/to-html';

// Elk artikel × elke taal
export async function getStaticPaths() {
  // Per taal ophalen, zodat elk artikel de vertaalde tekst krijgt
  const perTaal = await Promise.all(
    talen.map(async (taal) => ({
      taal,
      artikelen: (await getNieuwsArtikelen(taal)).filter((a) => a.slug),
    })),
  );
  return perTaal.flatMap(({ taal, artikelen }) =>
    artikelen.map((artikel) => ({
      params: { lang: taal === 'nl' ? undefined : taal, slug: artikel.slug },
      props: { artikel, taal },
    })),
  );
}

const { artikel, taal } = Astro.props;

// De volledige tekst uit het CMS omzetten naar HTML (leeg = alleen de samenvatting)
const tekst = artikel.body ? toHTML(artikel.body, { components: {} }) : '';

// Vindbaarheid: eigen SEO-velden hebben voorrang, anders de gewone tekst
const seoTitel = artikel.seoTitel || `${artikel.titel} — Stichting Gema Rasa`;
const seoBeschrijving = artikel.seoBeschrijving || artikel.intro;
const deelBeeld = artikel.seoAfbeelding || artikel.afbeelding;

// Structured data: dit is een nieuwsartikel (Google Nieuws + AI pikken dit op)
const artikelSchema = {
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  headline: artikel.titel,
  description: artikel.intro,
  image: deelBeeld ? [new URL(deelBeeld, Astro.site ?? Astro.url).toString()] : undefined,
  datePublished: artikel.datum || undefined,
  inLanguage: taal,
  author: { '@type': 'Organization', name: 'Stichting Gema Rasa' },
  publisher: {
    '@type': 'Organization',
    name: 'Stichting Gema Rasa',
    logo: { '@type': 'ImageObject', url: new URL('/assets/logo.png', Astro.site ?? Astro.url).toString() },
  },
};
---
<Base taal={taal} title={seoTitel} description={seoBeschrijving} ogImage={deelBeeld} ogType="article" jsonld={artikelSchema}>
  <section class="pagehead artikel-kop" style={`--hero-img:url('${artikel.afbeelding}')`}>
    <div class="wrap">
      <span class="eyebrow">{artikel.categorie}</span>
      <h1>{artikel.titel}</h1>
      {artikel.datumLabel && <p class="datum">{artikel.datumLabel}</p>}
    </div>
  </section>

  <section class="block">
    <div class="wrap">
      <article class="prose">
        <p class="lead">{artikel.intro}</p>
        {tekst && <div set:html={tekst} />}
        {!tekst && (
          <p style="font-size:14px;color:var(--gray)">{t(taal, "nw.geenTekst")}</p>
        )}
        <p style="margin-top:38px">
          <a class="btn" href={pad(taal, "/nieuws")}>{t(taal, "nw.alle")}</a>
        </p>
      </article>
    </div>
  </section>
</Base>
