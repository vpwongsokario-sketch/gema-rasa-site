---
import { taalPaden, t, pad } from '../../i18n/index.ts';
export const getStaticPaths = taalPaden;
const { taal } = Astro.props;
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
---
<Base taal={taal} description={t(taal, "dg.intro")} title={`${t(taal, "dg.titel")} — Stichting Gema Rasa`}>
  <PageHero
    sleutel="de-dansgroep"
    eyebrow={t(taal, "dg.eyebrow")}
    titel={t(taal, "dg.titel")}
    tekst={t(taal, "dg.intro")}
    foto="/assets/perf3.jpg"
  />

  <!-- DE NAAM ONTLEED -->
  <section class="block">
    <div class="wrap">
      <div class="prose">
        <h2>{t(taal, "dg.naamKop")}</h2>
        <p class="lead">{t(taal, "dg.naamIntro")}</p>
      </div>

      <div class="woorden">
        <div class="woord">
          <span class="woord-teken" aria-hidden="true">B</span>
          <h3>{t(taal, "dg.beksaKop")}</h3>
          <p>{t(taal, "dg.beksaTekst")}</p>
        </div>
        <div class="woord">
          <span class="woord-teken" aria-hidden="true">L</span>
          <h3>{t(taal, "dg.larasKop")}</h3>
          <p>{t(taal, "dg.larasTekst")}</p>
        </div>
        <div class="woord">
          <span class="woord-teken" aria-hidden="true">A</span>
          <h3>{t(taal, "dg.atiKop")}</h3>
          <p>{t(taal, "dg.atiTekst")}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- DE SYNERGIE -->
  <section class="block prod rond-boven rond-onder" data-parallax style="padding-top:64px;padding-bottom:64px">
    <div class="wrap">
      <div class="ornament op-donker" style="margin-bottom:34px"><span></span></div>
      <div class="prose" style="max-width:820px;margin:0 auto;text-align:center">
        <h2 style="color:#fff">{t(taal, "dg.synergieKop")}</h2>
        <p style="color:rgba(244,243,232,.9)">{t(taal, "dg.synergie1")}</p>
        <p style="color:rgba(244,243,232,.9)">{t(taal, "dg.synergie2")}</p>
      </div>
    </div>
  </section>

  <!-- MEEDOEN -->
  <section class="block">
    <div class="wrap">
      <div class="split">
        <div>
          <div class="section-head">
            <span class="kicker">{t(taal, "dg.meedoenKicker")}</span>
            <h2>{t(taal, "dg.meedoenTitel")}</h2>
            <p>{t(taal, "dg.meedoenTekst")}</p>
          </div>
          <a class="btn gold" href={pad(taal, "/steun#aanmelden")}>{t(taal, "dg.meedoenKnop")}</a>
        </div>
        <div>
          <div class="info-card">
            <h3>{t(taal, "sn.oefenKop")}</h3>
            <p>{t(taal, "sn.oefenTekst")}</p>
            <p style="margin-top:12px">{t(taal, "sn.oefenTekst2")}</p>
          </div>
          <div class="info-card" style="margin-top:18px">
            <h3>{t(taal, "sn.pratenKop")}</h3>
            <p>{t(taal, "sn.pratenTekst")}</p>
            <a href={pad(taal, "/contact")} class="btn" style="margin-top:10px">{t(taal, "sn.pratenKnop")}</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="cta">
    <div class="cta-inner">
      <h2>{t(taal, "dg.ctaTitel")}</h2>
      <p>{t(taal, "dg.ctaTekst")}</p>
      <a class="btn" href={pad(taal, "/menukaart")}>{t(taal, "dg.ctaKnop")}</a>
    </div>
  </section>
</Base>
