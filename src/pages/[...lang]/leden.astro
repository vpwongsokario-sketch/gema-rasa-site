---
import { taalPaden, t, pad } from '../../i18n/index.ts';
export const getStaticPaths = taalPaden;
const { taal } = Astro.props;
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
import { getLeden } from '../../lib/sanity.ts';
const { bestuur, leden } = await getLeden(taal);

// Initialen als er nog geen foto is geüpload
const initialen = (naam = '') =>
  naam.split(/[\s-]+/).filter(Boolean).map((w) => w[0]).slice(0, 2).join('').toUpperCase();
---
<Base taal={taal} title="De Leden — Stichting Gema Rasa">
  <PageHero
    sleutel="leden"
    eyebrow={t(taal, "ld.eyebrow")}
    titel={t(taal, "ld.titel")}
    tekst={t(taal, "ld.intro")}
    foto="/assets/perf-gamelan.jpg"
  />

  <section class="block">
    <div class="wrap">
      <div class="section-head">
        <span class="kicker">{t(taal, "ld.bestuurKicker")}</span>
        <h2>{t(taal, "ld.bestuurTitel")}</h2>
      </div>
      <div class="team-grid">
        {bestuur.map((m) => (
          <div class="member board">
            {m.foto
              ? <img class="avatar" src={m.foto} alt={m.naam} loading="lazy" />
              : <div class="avatar-fallback" aria-hidden="true">{initialen(m.naam)}</div>}
            <div class="naam">{m.naam}</div>
            <div class="rol">{m.rol}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="block" style="padding-top:0">
    <div class="wrap">
      <div class="section-head">
        <span class="kicker">{t(taal, "ld.groepKicker")}</span>
        <h2>{t(taal, "ld.groepTitel")}</h2>
        <p>{t(taal, "ld.groepTekst")}</p>
      </div>
      <div class="team-grid">
        {leden.map((m) => {
          // Iemand kan meerdere rollen hebben, bijv. gamelanspeler én vrijwilliger
          const extra = m.rollen?.includes('vrijwilliger') && !/vrijwillig/i.test(m.rol || '')
            ? t(taal, "ld.vrijwilliger") : null;
          const rolTekst = [m.rol, extra].filter(Boolean).join(' · ');
          return (
            <div class="member">
              {m.foto
                ? <img class="avatar" src={m.foto} alt={m.naam} loading="lazy" />
                : <div class="avatar-fallback" aria-hidden="true">{initialen(m.naam)}</div>}
              <div class="naam">{m.naam}</div>
              <div class="rol">{rolTekst}</div>
            </div>
          );
        })}
        <div class="member" style="border-style:dashed;display:flex;flex-direction:column;justify-content:center">
          <div class="naam">{t(taal, "ld.jij")}</div>
          <div class="rol">{t(taal, "ld.jijRol")}</div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="block" style="padding-top:0">
    <div class="wrap">
      <div class="section-head">
        <span class="kicker">{t(taal, "ld.faqKicker")}</span>
        <h2>{t(taal, "ld.faqTitel")}</h2>
      </div>
      <div class="prose">
        <h3>{t(taal, "ld.faq1V")}</h3>
        <p>{t(taal, "ld.faq1A")}</p>
        <h3>{t(taal, "ld.faq2V")}</h3>
        <p>{t(taal, "ld.faq2A")}</p>
      </div>
    </div>
  </section>
</Base>
