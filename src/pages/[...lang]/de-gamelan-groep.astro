---
import { taalPaden, t, pad } from '../../i18n/index.ts';
export const getStaticPaths = taalPaden;
const { taal } = Astro.props;
const paginaSeo = await getPaginaSeo('de-gamelan-groep');
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
import { getLeden , getPaginaSeo} from '../../lib/sanity.ts';
const { gamelan, ensembles } = await getLeden(taal);

const initialen = (naam = '') =>
  naam.split(/[\s-]+/).filter(Boolean).map((w) => w[0]).slice(0, 2).join('').toUpperCase();

// De drie ensembles binnen Jiwa Manunggal. Deze staan er altijd — ze horen bij
// de organisatie, ook als er nog niemand aan is toegewezen in het CMS.
const groepen = [
  { sleutel: 'young', leden: ensembles.young },
  { sleutel: 'silver', leden: ensembles.silver },
  { sleutel: 'mix', leden: ensembles.mix },
];

// Iedereen wordt in één raster getoond; de filterknoppen bepalen wie zichtbaar is.
// Zo hoeven leden die in meerdere ensembles spelen niet dubbel te verschijnen.
const alleMusici = gamelan;
---
<Base taal={taal} seo={paginaSeo} description={t(taal, "gg.intro")} title={`${t(taal, "gg.titel")} — Stichting Gema Rasa`}>
  <PageHero
    sleutel="de-gamelan-groep"
    eyebrow={t(taal, "gg.eyebrow")}
    titel={t(taal, "gg.titel")}
    tekst={t(taal, "gg.intro")}
    foto="/assets/perf2.jpg"
  />

  <section class="block">
    <div class="wrap">
      <div class="prose">
        <h2>{t(taal, "gg.naamKop")}</h2>
        <h3>{t(taal, "gg.jiwaKop")}</h3>
        <p>{t(taal, "gg.jiwaTekst")}</p>
        <h3>{t(taal, "gg.manunggalKop")}</h3>
        <p>{t(taal, "gg.manunggalTekst")}</p>
        <p>{t(taal, "gg.samenTekst")}</p>
      </div>
    </div>
  </section>

  <!-- DE DRIE ENSEMBLES + MUSICI -->
  <section class="block batik" style="padding-top:0" id="ensembles">
    <div class="wrap">
      <div class="ornament" style="margin-bottom:46px"><span></span></div>
      <div class="section-head">
        <span class="kicker">{t(taal, "gg.ensKicker")}</span>
        <h2>{t(taal, "gg.ensTitel")}</h2>
        <p>{t(taal, "gg.ensIntro")}</p>
      </div>

      {/* Filterknoppen: iedereen staat in één raster, dus wie in twee ensembles
          speelt verschijnt niet dubbel op de pagina. */}
      <div class="filters" id="ensFilters">
        <button class="chip active" data-ens="all">
          {t(taal, "gg.allen")} <span class="chip-tel">{alleMusici.length}</span>
        </button>
        {groepen.map((g) => (
          <button class="chip" data-ens={g.sleutel}>
            {t(taal, `gg.${g.sleutel}Kort`)} <span class="chip-tel">{g.leden.length}</span>
          </button>
        ))}
      </div>

      {/* Toelichting bij het gekozen ensemble */}
      <div class="ens-uitleg" id="ensUitleg">
        <div data-uitleg="all" class="actief">
          <h3>{t(taal, "gg.allenTitel")}</h3>
          <p>{t(taal, "gg.ensIntro")}</p>
        </div>
        {groepen.map((g) => (
          <div data-uitleg={g.sleutel}>
            <h3>{t(taal, `gg.${g.sleutel}Naam`)} <span class="ens-leeftijd">{t(taal, `gg.${g.sleutel}Leeftijd`)}</span></h3>
            <p>{t(taal, `gg.${g.sleutel}Tekst`)}</p>
          </div>
        ))}
      </div>

      <div class="team-grid" id="ensGrid">
        {alleMusici.map((m) => (
          <div class="member" data-ens={m.ensembles.join(' ')}>
            {m.foto
              ? <img class="avatar" src={m.foto} alt={m.naam} loading="lazy" />
              : <div class="avatar-fallback" aria-hidden="true">{initialen(m.naam)}</div>}
            <div class="naam">{m.naam}</div>
            <div class="rol">{m.rol}</div>
          </div>
        ))}
      </div>
      <p class="ens-leeg" id="ensLeeg" hidden>{t(taal, "gg.nogIndelen")}</p>
    </div>
  </section>

  <section class="cta">
    <div class="cta-inner">
      <h2>{t(taal, "gg.ctaTitel")}</h2>
      <p>{t(taal, "gg.ctaTekst")}</p>
      <a class="btn" href={pad(taal, "/menukaart")}>{t(taal, "gg.ctaKnop")}</a>
    </div>
  </section>
</Base>

<script>
  // Filter de musici op ensemble
  const chips = document.querySelectorAll<HTMLButtonElement>('#ensFilters .chip');
  const kaarten = document.querySelectorAll<HTMLElement>('#ensGrid .member');
  const uitleg = document.querySelectorAll<HTMLElement>('#ensUitleg [data-uitleg]');
  const leeg = document.getElementById('ensLeeg');

  chips.forEach((c) => c.addEventListener('click', () => {
    const keuze = c.dataset.ens || 'all';
    chips.forEach((x) => x.classList.toggle('active', x === c));
    uitleg.forEach((u) => u.classList.toggle('actief', u.dataset.uitleg === keuze));

    let zichtbaar = 0;
    kaarten.forEach((kaart) => {
      const hoort = keuze === 'all' || (kaart.dataset.ens || '').split(' ').includes(keuze);
      kaart.style.display = hoort ? '' : 'none';
      if (hoort) zichtbaar++;
    });
    if (leeg) leeg.hidden = zichtbaar > 0;
  }));
</script>
