---
import { taalPaden, t, pad } from '../../i18n/index.ts';
export const getStaticPaths = taalPaden;
const { taal } = Astro.props;
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
import { getLeden } from '../../lib/sanity.ts';
const { gamelan, ensembles } = await getLeden(taal);

const initialen = (naam = '') =>
  naam.split(/[\s-]+/).filter(Boolean).map((w) => w[0]).slice(0, 2).join('').toUpperCase();

// De drie ensembles binnen Jiwa Manunggal. Deze staan er altijd — ze horen bij
// de organisatie, ook als er nog niemand aan is toegewezen in het CMS.
const groepen = [
  { sleutel: 'young', leden: ensembles.young, foto: '/assets/perf4.jpg' },
  { sleutel: 'silver', leden: ensembles.silver, foto: '/assets/perf-gamelan.jpg' },
  { sleutel: 'mix', leden: ensembles.mix, foto: '/assets/perf2.jpg' },
];

// Is er al iemand ingedeeld? Zo niet, dan tonen we onderaan gewoon alle musici.
const ingedeeld = groepen.some((g) => g.leden.length > 0);
---
<Base taal={taal} title={`${t(taal, "gg.titel")} — Stichting Gema Rasa`}>
  <PageHero
    sleutel="de-gamelan-groep"
    eyebrow={t(taal, "gg.eyebrow")}
    titel={t(taal, "gg.titel")}
    tekst={t(taal, "gg.intro")}
    foto="/assets/perf2.jpg"
  />

  <section class="block">
    <div class="wrap">
      <div class="prose">
        <h2>{t(taal, "gg.naamKop")}</h2>
        <h3>{t(taal, "gg.jiwaKop")}</h3>
        <p>{t(taal, "gg.jiwaTekst")}</p>
        <h3>{t(taal, "gg.manunggalKop")}</h3>
        <p>{t(taal, "gg.manunggalTekst")}</p>
        <p>{t(taal, "gg.samenTekst")}</p>
      </div>
    </div>
  </section>

  <!-- DE DRIE ENSEMBLES -->
  <section class="block batik" style="padding-top:0">
    <div class="wrap">
      <div class="ornament" style="margin-bottom:46px"><span></span></div>
      <div class="section-head">
        <span class="kicker">{t(taal, "gg.ensKicker")}</span>
        <h2>{t(taal, "gg.ensTitel")}</h2>
        <p>{t(taal, "gg.ensIntro")}</p>
      </div>

      <div class="ensembles">
        {groepen.map((g) => (
          <article class="ensemble">
            <div class="ens-beeld" style={`background-image:url('${g.foto}')`}>
              {g.leden.length > 0 && (
                <span class="ens-aantal">{g.leden.length} {t(taal, "gg.leden")}</span>
              )}
            </div>
            <div class="ens-body">
              <h3>{t(taal, `gg.${g.sleutel}Naam`)}</h3>
              <span class="ens-leeftijd">{t(taal, `gg.${g.sleutel}Leeftijd`)}</span>
              <p>{t(taal, `gg.${g.sleutel}Tekst`)}</p>
              {g.leden.length > 0 && (
                <ul class="ens-leden">
                  {g.leden.map((m) => (
                    <li><strong>{m.naam}</strong>{m.rol && <span> · {m.rol}</span>}</li>
                  ))}
                </ul>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ALLE MUSICI -->
  <section class="block" style="padding-top:0">
    <div class="wrap">
      <div class="section-head">
        <span class="kicker">{t(taal, "gg.musiciKicker")}</span>
        <h2>{ingedeeld ? t(taal, "gg.overigTitel") : t(taal, "gg.musiciTitel")}</h2>
        {ingedeeld && ensembles.overig.length > 0 && <p>{t(taal, "gg.nogIndelen")}</p>}
      </div>
      <div class="team-grid">
        {(ingedeeld ? ensembles.overig : gamelan).map((m) => (
          <div class="member">
            {m.foto
              ? <img class="avatar" src={m.foto} alt={m.naam} loading="lazy" />
              : <div class="avatar-fallback" aria-hidden="true">{initialen(m.naam)}</div>}
            <div class="naam">{m.naam}</div>
            <div class="rol">{m.rol}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="cta">
    <div class="cta-inner">
      <h2>{t(taal, "gg.ctaTitel")}</h2>
      <p>{t(taal, "gg.ctaTekst")}</p>
      <a class="btn" href={pad(taal, "/menukaart")}>{t(taal, "gg.ctaKnop")}</a>
    </div>
  </section>
</Base>
