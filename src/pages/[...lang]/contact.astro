---
import { taalPaden, t, pad } from '../../i18n/index.ts';
export const getStaticPaths = taalPaden;
const { taal } = Astro.props;
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
import { contact } from '../../data/content.js';
---
<Base taal={taal} description={t(taal, "ct.intro")} title={`${t(taal, "ct.titel")} — Stichting Gema Rasa`}>
  <PageHero
    sleutel="contact"
    eyebrow={t(taal, "ct.eyebrow")}
    titel={t(taal, "ct.titel")}
    tekst={t(taal, "ct.intro")}
    foto="/assets/perf4.jpg"
  />

  <section class="block">
    <div class="wrap">
      <div class="split">
        <div>
          <form class="cform" data-formulier="contact" data-bedankt={t(taal, "ct.bedankt")}>
            <div>
              <label for="naam">{t(taal, "ct.naam")}</label>
              <input id="naam" name="naam" type="text" required />
            </div>
            <div>
              <label for="email">{t(taal, "ct.email")}</label>
              <input id="email" name="email" type="email" required />
            </div>
            <div>
              <label for="onderwerp">{t(taal, "ct.onderwerp")}</label>
              <input id="onderwerp" name="onderwerp" type="text" />
            </div>
            <div>
              <label for="bericht">{t(taal, "ct.bericht")}</label>
              <textarea id="bericht" name="bericht" required></textarea>
            </div>
            <input type="text" name="website" tabindex="-1" autocomplete="off" class="honeypot" aria-hidden="true" />
            <button class="btn gold" type="submit" style="justify-self:start">{t(taal, "ct.verstuur")}</button>
            <p class="form-status" data-status role="status" aria-live="polite"></p>
            <p style="font-family:'Poppins';font-size:12.5px;color:var(--gray);line-height:1.5">{t(taal, "ct.privacy")}</p>
          </form>
        </div>
        <div>
          <div class="section-head" style="margin-bottom:20px">
            <span class="kicker">{t(taal, "ct.locatiesKicker")}</span>
            <h2 style="font-size:26px">{t(taal, "ct.locatiesTitel")}</h2>
          </div>
          <div class="info-cards">
            {contact.locaties.map((l) => (
              <div class="info-card">
                <h3>{l.plaats}</h3>
                <p>{l.adres}</p>
                <a href={`tel:${contact.telefoon.replace(/[^+0-9]/g, '')}`}>{contact.telefoon}</a>
                <a href={`mailto:${contact.email}`}>{contact.email}</a>
              </div>
            ))}
          </div>
          <p style="font-family:'Poppins';font-weight:300;font-size:13px;color:var(--gray);margin-top:16px">
            KVK: {contact.kvk} &middot; BTW: {contact.btw}
          </p>
        </div>
      </div>
    </div>
  </section>

</Base>
