---
import { taalPaden, t, pad } from '../../i18n/index.ts';
export const getStaticPaths = taalPaden;
const { taal } = Astro.props;
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
import { getVrienden } from '../../lib/sanity.ts';
const vrienden = await getVrienden();
---
<Base taal={taal} title="De Vrienden van — Stichting Gema Rasa">
  <PageHero
    sleutel="de-vrienden-van"
    eyebrow={t(taal, "vr.eyebrow")}
    titel={t(taal, "vr.titel")}
    tekst={t(taal, "vr.intro")}
    foto="/assets/perf3.jpg"
  />

  <section class="block">
    <div class="wrap">
      <div class="team-grid">
        {vrienden.map((v) => {
          const Kaart = v.website ? 'a' : 'div';
          return (
            <Kaart class="member" href={v.website || undefined} target={v.website ? '_blank' : undefined} rel={v.website ? 'noopener' : undefined}>
              {v.logo
                ? <div class="logo-wrap"><img src={v.logo} alt={v.naam} loading="lazy" /></div>
                : <div class="logo-fallback" aria-hidden="true">{v.naam.slice(0, 2).toUpperCase()}</div>}
              <div class="rol" style="color:var(--orange);text-transform:uppercase;letter-spacing:.08em;font-size:11px;font-weight:600">{v.type}</div>
              <div class="naam" style="margin-top:4px">{v.naam}</div>
              <div class="rol">{v.omschrijving}</div>
            </Kaart>
          );
        })}
      </div>
    </div>
  </section>

  <section class="cta">
    <div class="cta-inner">
      <h2>{t(taal, "vr.ctaTitel")}</h2>
      <p>{t(taal, "vr.ctaTekst")}</p>
      <a class="btn" href={pad(taal, "/contact")}>{t(taal, "vr.ctaKnop")}</a>
    </div>
  </section>
</Base>
