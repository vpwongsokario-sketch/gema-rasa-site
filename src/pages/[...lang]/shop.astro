---
import { taalPaden, t, pad } from '../../i18n/index.ts';
export const getStaticPaths = taalPaden;
const { taal } = Astro.props;
const paginaSeo = await getPaginaSeo('shop');
import { getPaginaSeo } from '../../lib/sanity.ts';
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
---
<Base taal={taal} seo={paginaSeo} description={t(taal, "sh.intro")} title={`${t(taal, "sh.titel")} — Stichting Gema Rasa`}>
  <PageHero
    sleutel="shop"
    eyebrow={t(taal, "sh.eyebrow")}
    titel={t(taal, "sh.titel")}
    tekst={t(taal, "sh.intro")}
    foto="/assets/perf4.jpg"
  />

  <section class="block">
    <div class="wrap">
      <div class="prose">
        <p class="lead">{t(taal, "sh.lead")}</p>
        <p>{t(taal, "sh.p1")}</p>
        <p><a class="btn gold" href={pad(taal, "/contact")}>{t(taal, "sh.knop")}</a></p>
      </div>
    </div>
  </section>
</Base>
