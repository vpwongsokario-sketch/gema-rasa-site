---
import { taalPaden, t, pad } from '../../i18n/index.ts';
export const getStaticPaths = taalPaden;
const { taal } = Astro.props;
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
---
<Base taal={taal} title="Shop — Stichting Gema Rasa">
  <PageHero
    sleutel="shop"
    eyebrow="SGR Merchandise"
    titel="Onze webshop"
    tekst="Exclusieve merchandise, met zorg ontworpen door de jongeren van Stichting Gema Rasa. Met jouw aankoop steun je onze culturele projecten."
    foto="/assets/perf4.jpg"
  />

  <section class="block">
    <div class="wrap">
      <div class="prose">
        <p class="lead">De webshop wordt in de volgende stap opgezet met een lichte
          winkelwagen-oplossing (Snipcart), zodat producten, prijzen en bestellingen makkelijk te
          beheren zijn — zonder duur e-commerceplatform.</p>
        <p>Wil je nu al iets bestellen of meer weten over de collectie? Neem gerust contact op.</p>
        <p><a class="btn gold" href="/contact">Contact over merchandise</a></p>
      </div>
    </div>
  </section>
</Base>
