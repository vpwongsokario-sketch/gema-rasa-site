---
import Base from '../layouts/Base.astro';
import { contact } from '../data/content.js';
---
<Base title="Contact — Stichting Gema Rasa">
  <section class="pagehead">
    <div class="wrap">
      <span class="eyebrow">Contact</span>
      <h1>Stuur ons een bericht</h1>
      <p>Vragen over een boeking, meedoen of samenwerken? We horen graag van je.</p>
    </div>
  </section>

  <section class="block">
    <div class="wrap">
      <div class="split">
        <div>
          <form class="cform" id="contactForm" onsubmit="return false">
            <div>
              <label for="naam">Naam</label>
              <input id="naam" name="naam" type="text" required />
            </div>
            <div>
              <label for="email">E-mailadres</label>
              <input id="email" name="email" type="email" required />
            </div>
            <div>
              <label for="onderwerp">Onderwerp</label>
              <input id="onderwerp" name="onderwerp" type="text" />
            </div>
            <div>
              <label for="bericht">Bericht</label>
              <textarea id="bericht" name="bericht" required></textarea>
            </div>
            <button class="btn gold" type="submit">Verstuur bericht</button>
            <p id="formNote" style="font-family:'Poppins';font-size:13px;color:var(--gray)"></p>
          </form>
        </div>
        <div>
          <div class="section-head" style="margin-bottom:20px">
            <span class="kicker">Onze locaties</span>
            <h2 style="font-size:26px">Waar je ons vindt</h2>
          </div>
          <div class="info-cards">
            {contact.locaties.map((l) => (
              <div class="info-card">
                <h3>{l.plaats}</h3>
                <p>{l.adres}</p>
                <a href={`tel:${contact.telefoon.replace(/[^+0-9]/g, '')}`}>{contact.telefoon}</a>
                <a href={`mailto:${contact.email}`}>{contact.email}</a>
              </div>
            ))}
          </div>
          <p style="font-family:'Poppins';font-weight:300;font-size:13px;color:var(--gray);margin-top:16px">
            KVK: {contact.kvk} &middot; BTW: {contact.btw}
          </p>
        </div>
      </div>
    </div>
  </section>

  <script>
    // Tijdelijke afhandeling — wordt straks gekoppeld aan een formulierdienst (bv. Formspree)
    const form = document.getElementById('contactForm') as HTMLFormElement | null;
    const note = document.getElementById('formNote');
    form?.addEventListener('submit', () => {
      if (note) note.textContent = 'Bedankt! Je bericht is genoteerd — koppeling met e-mail volgt in de volgende stap.';
      form.reset();
    });
  </script>
</Base>
