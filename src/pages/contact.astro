---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import { contact } from '../data/content.js';
---
<Base title="Contact — Stichting Gema Rasa">
  <PageHero
    sleutel="contact"
    eyebrow="Contact"
    titel="Stuur ons een bericht"
    tekst="Vragen over een boeking, meedoen of samenwerken? We horen graag van je."
    foto="/assets/perf4.jpg"
  />

  <section class="block">
    <div class="wrap">
      <div class="split">
        <div>
          <form class="cform" data-formulier="contact" data-bedankt="Bedankt! We hebben je bericht ontvangen en nemen snel contact op.">
            <div>
              <label for="naam">Naam</label>
              <input id="naam" name="naam" type="text" required />
            </div>
            <div>
              <label for="email">E-mailadres</label>
              <input id="email" name="email" type="email" required />
            </div>
            <div>
              <label for="onderwerp">Onderwerp</label>
              <input id="onderwerp" name="onderwerp" type="text" />
            </div>
            <div>
              <label for="bericht">Bericht</label>
              <textarea id="bericht" name="bericht" required></textarea>
            </div>
            <input type="text" name="website" tabindex="-1" autocomplete="off" class="honeypot" aria-hidden="true" />
            <button class="btn gold" type="submit" style="justify-self:start">Verstuur bericht</button>
            <p class="form-status" data-status role="status" aria-live="polite"></p>
            <p style="font-family:'Poppins';font-size:12.5px;color:var(--gray);line-height:1.5">
              We gebruiken je gegevens alleen om je vraag te beantwoorden.
            </p>
          </form>
        </div>
        <div>
          <div class="section-head" style="margin-bottom:20px">
            <span class="kicker">Onze locaties</span>
            <h2 style="font-size:26px">Waar je ons vindt</h2>
          </div>
          <div class="info-cards">
            {contact.locaties.map((l) => (
              <div class="info-card">
                <h3>{l.plaats}</h3>
                <p>{l.adres}</p>
                <a href={`tel:${contact.telefoon.replace(/[^+0-9]/g, '')}`}>{contact.telefoon}</a>
                <a href={`mailto:${contact.email}`}>{contact.email}</a>
              </div>
            ))}
          </div>
          <p style="font-family:'Poppins';font-weight:300;font-size:13px;color:var(--gray);margin-top:16px">
            KVK: {contact.kvk} &middot; BTW: {contact.btw}
          </p>
        </div>
      </div>
    </div>
  </section>

</Base>
