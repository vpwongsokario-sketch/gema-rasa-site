---
import Base from '../layouts/Base.astro';
import { getHomepage, getNieuws, getAgenda } from '../lib/sanity.ts';

const { hero, productie } = await getHomepage();
const nieuws = await getNieuws();
const agenda = await getAgenda();

// Titel met accent-woord in goud (uit CMS)
const [voorAccent, naAccent] = hero.titelAccent && hero.titel.includes(hero.titelAccent)
  ? hero.titel.split(hero.titelAccent)
  : [hero.titel, ''];
---
<Base>
  <!-- HERO (via CMS) -->
  <section class="hero" id="top" style={`--hero-img:url('${hero.afbeelding}')`}>
    <div class="wrap">
      <div class="hero-inner">
        <span class="eyebrow">{hero.eyebrow}</span>
        <h1>{voorAccent}{naAccent && <em>{hero.titelAccent}</em>}{naAccent}</h1>
        <p class="lead">{hero.tekst}</p>
        <div class="hero-cta">
          <a class="btn gold" href={hero.knopUrl}>{hero.knopLabel}</a>
          <a class="btn ghost" style="color:var(--cream);border-color:rgba(239,200,62,.5)" href="#nieuws">Bekijk nieuws</a>
        </div>
      </div>
    </div>
  </section>

  <div class="strip">
    <div class="wrap">
      <span><b>Live gamelan</b> — orkest Jiwa Manunggal</span>
      <span><b>Javaanse dans</b> &amp; theater</span>
      <span><b>Educatie</b> &amp; workshops</span>
      <span><b>Verhalen</b> uit de Javaanse traditie</span>
    </div>
  </div>

  <!-- UITGELICHTE PRODUCTIE (via CMS) -->
  {productie.actief && (
    <section class="block prod" id="productie">
      <div class="wrap">
        <div class="inner">
          <div class="art" style={`background-image:url('${productie.afbeelding}')`}>
            <span class="date-badge">{productie.datumLabel}</span>
          </div>
          <div>
            <span class="kicker" style="color:var(--primary);font-family:'Poppins';font-weight:600;letter-spacing:.13em;text-transform:uppercase;font-size:12.5px">{productie.kicker}</span>
            <h2>{productie.titel}</h2>
            <p>{productie.intro}</p>
            <p>{productie.beschrijving}</p>
            {productie.citaat && <p class="quote">"{productie.citaat}"</p>}
            <a class="btn gold" href={productie.knopUrl}>{productie.knopLabel}</a>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- MERCHANDISE -->
  <section class="block" style="padding-top:0">
    <div class="wrap">
      <div class="merch">
        <div class="img" style="background-image:url('/assets/perf4.jpg')"></div>
        <div class="body">
          <span class="kicker">SGR Merchandise</span>
          <h2>Steun cultuur met een exclusief aandenken</h2>
          <p>Onze exclusieve merchandise is met zorg en creativiteit ontworpen door de jongeren
            van Stichting Gema Rasa.</p>
          <p>Met jouw aankoop steun je niet alleen onze culturele projecten, maar draag je ook bij
            aan het behoud en de promotie van Javaanse muziek en dans.</p>
          <a class="btn" href="/shop" style="margin-top:8px">Shop</a>
        </div>
      </div>
    </div>
  </section>

  <!-- OVER DE STICHTING: GEMA & RASA -->
  <section class="block" id="over" style="padding-top:0">
    <div class="wrap">
      <div class="section-head">
        <span class="kicker">De Stichting</span>
        <h2>Stichting Gema Rasa</h2>
        <p>Een culturele organisatie die zich met passie en toewijding inzet voor de promotie van
          Javaanse muziek en dans, en de rijke tradities van Java naar een breed publiek brengt.</p>
      </div>
      <div class="duo">
        <div class="word">
          <h3>Gema</h3>
          <p>Letterlijk vertaald betekent "gema" "echo" in het Javaans en Indonesisch. In de context
            van de stichting symboliseert dit de weerklank van de Javaanse cultuur en tradities die
            resoneren door de generaties heen.</p>
        </div>
        <div class="word">
          <h3>Rasa</h3>
          <p>"Rasa" kan vertaald worden als "gevoel", "smaak" of "essentie". Het verwijst naar de
            diepe emotionele verbinding en het gevoel dat men krijgt bij het beoefenen en ervaren
            van Javaanse dans en muziek.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- NIEUWS -->
  <section class="block" id="nieuws" style="padding-top:0">
    <div class="wrap">
      <div class="section-head">
        <span class="kicker">Foto's, Video's &amp; Nieuws</span>
        <h2>Bekijk onze optredens en evenementen</h2>
        <p>Het laatste nieuws van het gamelanorkest en de projecten van Stichting Gema Rasa.</p>
      </div>
      <div class="news-grid">
        {nieuws.map((n) => (
          <a class="news" href={`/nieuws/${n.slug}`}>
            <div class="thumb" style={`background-image:url('${n.afbeelding}')`}></div>
            <div class="np">
              <span class="cat">{n.categorie}</span>
              <h3>{n.titel}</h3>
              <p>{n.intro.length > 160 ? n.intro.slice(0, 160) + '…' : n.intro}</p>
              <span class="more">Lees meer →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA: BOEK GEMA RASA → menukaart -->
  <section class="cta">
    <div class="cta-inner">
      <h2>Nodig Gema Rasa uit voor uw evenement</h2>
      <p>Beleef de betoverende muziek van de Gamelan Groep Jiwa Manunggal van Stichting Gema Rasa.
        Benieuwd wat we voor jou kunnen betekenen? Bekijk onze culturele menukaart.</p>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap">
        <a class="btn" href="/menukaart">Bekijk wat we bieden</a>
        <a class="btn ghost" href="/contact">Direct contact</a>
      </div>
    </div>
  </section>

  <!-- AGENDA -->
  <section class="block" id="agenda">
    <div class="wrap">
      <div class="section-head">
        <span class="kicker">Agenda</span>
        <h2>Evenementen die wij ondersteunen</h2>
        <p>Evenementen waar onze gamelangroep Jiwa Manunggal optreedt of die helpen met het
          verspreiden van de Javaanse cultuur.</p>
      </div>
      <div class="agenda">
        {agenda.map((e) => (
          <div class="row">
            <span class="d">{e.datumLabel}</span>
            <span class="t">{e.titel}</span>
            <span class="loc">{e.locatie}</span>
          </div>
        ))}
      </div>
    </div>
  </section>
</Base>
