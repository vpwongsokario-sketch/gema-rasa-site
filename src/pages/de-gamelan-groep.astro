---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import { getLeden } from '../lib/sanity.ts';
const { gamelan } = await getLeden();

const initialen = (naam = '') =>
  naam.split(/[\s-]+/).filter(Boolean).map((w) => w[0]).slice(0, 2).join('').toUpperCase();
---
<Base title="De Gamelangroep Jiwa Manunggal — Stichting Gema Rasa">
  <PageHero
    sleutel="de-gamelan-groep"
    eyebrow="De Gamelangroep"
    titel="Jiwa Manunggal"
    tekst="Zielen die samenkomen in eenheid — een collectieve uiting die groter is dan de som der delen."
    foto="/assets/perf2.jpg"
  />

  <section class="block">
    <div class="wrap">
      <div class="prose">
        <h2>De naam</h2>
        <h3>Jiwa — ziel</h3>
        <p>"Jiwa" betekent "ziel": de essentie en innerlijke geest van individu en gemeenschap. Het
          omvat de emoties, gevoelens en passie die artiesten en luisteraars verbinden, en de
          persoonlijke verrijking die een culturele ervaring geeft.</p>
        <h3>Manunggal — verenigd</h3>
        <p>"Manunggal" betekent "verenigd" of "samen". Het benadrukt de samenhang binnen de groep:
          hoe individuele talenten samensmelten tot een harmonieus geheel.</p>
        <p><strong>Jiwa Manunggal</strong> verbeeldt zielen die samenkomen in eenheid — een
          weerspiegeling van de visie van Stichting Gema Rasa om met Javaanse kunsten sterkere,
          verbonden gemeenschappen te bouwen.</p>
      </div>
    </div>
  </section>

  <section class="block" style="padding-top:0">
    <div class="wrap">
      <div class="section-head">
        <span class="kicker">De musici</span>
        <h2>Wie het orkest vormen</h2>
      </div>
      <div class="team-grid">
        {gamelan.map((m) => (
          <div class="member">
            {m.foto
              ? <img class="avatar" src={m.foto} alt={m.naam} loading="lazy" />
              : <div class="avatar-fallback" aria-hidden="true">{initialen(m.naam)}</div>}
            <div class="naam">{m.naam}</div>
            <div class="rol">{m.rol}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="cta">
    <div class="cta-inner">
      <h2>Nodig Jiwa Manunggal uit voor uw evenement</h2>
      <p>Beleef de betoverende muziek van de gamelangroep van Stichting Gema Rasa — live op uw podium.</p>
      <a class="btn" href="/menukaart">Bekijk het aanbod</a>
    </div>
  </section>
</Base>
